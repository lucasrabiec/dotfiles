# Dynamic theme colors
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
font-family = "FiraCode Nerd Font"
font-style = Regular
font-size = 10

# Window
window-theme = ghostty
window-padding-x = 14
window-padding-y = 14
confirm-close-surface=false
resize-overlay = never

# Panes / Splits
unfocused-split-opacity = 0.55

# Tabs styling
gtk-toolbar-style = flat
gtk-wide-tabs = false
gtk-custom-css = tab-style.css

# Cursor styling
cursor-style = "block"
cursor-style-blink = false

# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env

# Keyboard bindings
## Unbind defaults
keybind = control+shift+alt+j=unbind # for Tmux navigation between sessions

# Custom bindings
## Clipboard
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard

## Scrolling
keybind = control+alt+u=scroll_page_up
keybind = control+alt+d=scroll_page_down

## Splits
keybind = control+shift+alt+j=resize_split:down,100
keybind = control+shift+alt+k=resize_split:up,100
keybind = control+shift+alt+h=resize_split:left,100
keybind = control+shift+alt+l=resize_split:right,100
keybind = control+shift+j=goto_split:down
keybind = control+shift+k=goto_split:up
keybind = control+shift+h=goto_split:left
keybind = control+shift+l=goto_split:right

## Tabs
keybind = control+shift+alt+[=previous_tab
keybind = control+shift+alt+]=next_tab

## Surface
keybind = control+shift+c=close_surface

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Theme
theme = dracula

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll
