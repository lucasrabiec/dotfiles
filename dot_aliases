# General
alias cc='clear'

# LSD
alias ls='lsd'
alias l='ls --group-dirs=first'
alias la='ls -a --group-dirs=first'
alias ll='ls -l --group-dirs=first'
alias lla='ls -la --group-dirs=first'
alias lt='ls --tree --group-dirs first --depth=2 2>/dev/null'

# Git
alias gac='git add . && git commit'
alias gc='git checkout '
alias gcm='git checkout main && git pull'
alias gl='git log --oneline --all --graph --decorate $*'
alias gpl='git pull'
alias gph='git push'
alias gri='git rebase -i `git merge-base HEAD main`'
alias grm='git rebase main'
alias gst='git status'
alias gsu='git submodule update --remote'

# Paths
alias cdw='cd ~/Work/'
cdwc() { cd ~/Work/$1 ; }

# Directories
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'

# Cal
alias cal='cal -m' # Monday as first day

# Tools
alias c='opencode'
alias cx='printf "\033[2J\033[3J\033[H" && claude --allow-dangerously-skip-permissions'
alias d='docker'
alias r='rails'
alias t='tmux attach || tmux new -s Work'
n() { if [ "$#" -eq 0 ]; then command nvim . ; else command nvim "$@"; fi; }
alias lg='lazygit'

