# removes merged local branches
gcm() {
  git fetch --prune origin

  branches=$(git branch -vv \
    | grep ': gone]' \
    | grep -vE '^\*| main | master | develop ' \
    | awk '{print $1}')

  if [ -z "$branches" ]; then
    echo "No gone local branches to delete"
    return 0
  fi

  echo "Deleting gone local branches:"
  echo "$branches"

  echo "$branches" | xargs -n 1 git branch -D
}

